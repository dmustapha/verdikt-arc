# Verdikt (Arc edition) — credentials manifest. Copy to .env and fill. NEVER commit .env.
# Placeholder values only. Before generating new keys, check past .env files (solv-001) for reusable creds.

# ── Arc testnet ───────────────────────────────────────────────────────────────
ARC_RPC_URL=https://rpc.testnet.arc.network            # Arc RPC — confirm 5042002 via `cast chain-id`
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network # client RPC (web)

# ── VerdiktEscrow (record after Phase 1 deploy) ──────────────────────────────
ESCROW_ADDRESS=DEPLOY_AND_RECORD_ADDRESS_HERE
NEXT_PUBLIC_ESCROW_ADDRESS=DEPLOY_AND_RECORD_ADDRESS_HERE

# ── Contract deploy (gas paid in USDC — fund via faucet.circle.com) ──────────
DEPLOYER_PRIVATE_KEY=0xGENERATE_AT_DEPLOY              # generated in PLAN Task 0.2
DEPLOYER_ADDRESS=0xGENERATE_AT_DEPLOY

# ── Circle Developer-Controlled Wallet = escrow onlyVerdict settlement wallet ─
# obtain from console.circle.com (reuse solv-001). Required before: deploy
CIRCLE_API_KEY=TEST_API_KEY:placeholder
CIRCLE_ENTITY_SECRET=placeholder
CIRCLE_WALLET_ID=placeholder
VERDICT_WALLET_ADDRESS=0xCIRCLE_DCW_ADDRESS           # = the DCW address; passed to the deploy constructor

ANTHROPIC_API_KEY=sk-ant-placeholder
REASONER_MODEL=claude-sonnet-4-6
GROUNDING_MODEL=claude-sonnet-4-6

# ── Code-route sandbox ───────────────────────────────────────────────────────
RUNNER_IMAGE=verdikt-runner
FIXTURES_DIR=../fixtures

# ── Ledger DB (Neon / Vercel Postgres) ──────────────────────────────────────
POSTGRES_URL=postgres://user:pass@host/db

# ── x402 verdict fee via Gateway (C13) ───────────────────────────────────────
VERDICT_FEE_WALLET_ADDRESS=0xFEE_WALLET               # receives the sub-cent fee
VERDICT_FEE_USDC=0.001
ENFORCE_X402=true                                     # set false only for internal/local runs
WORKER_GATEWAY_KEY=0xGENERATE                         # worker EOA paying the fee (deposit via Gateway)

# ── Receipt signing (C9) ─────────────────────────────────────────────────────
RECEIPT_SIGNER_KEY=0xGENERATE

# ── Demo agents (generate; fund payer via faucet.circle.com 20/2h) ───────────
DEMO_PAYER_KEY=0xGENERATE
DEMO_PAYER_ADDRESS=0xGENERATE
DEMO_WORKER_ADDRESS=0xGENERATE

# ── Worker <-> web wiring + guards ───────────────────────────────────────────
WORKER_URL=http://localhost:8080                      # web → worker base URL
WEB_ORIGIN=http://localhost:3000                      # worker CORS allowlist for money routes
DEMO_SHARED_SECRET=generate_a_random_string           # guards /api/demo (money-moving)

# ── Public "Try it" rail (/api/try) — bring-your-own-task, funded by the demo wallet ─────────
TRY_MAX_USDC=0.1                                       # escrow size per public run (clamped; caller cannot raise)
TRY_PER_IP=3                                           # max runs per IP per window
TRY_IP_WINDOW_MS=600000                                # per-IP window (10 min)
TRY_GLOBAL_DAY=60                                      # global daily cap (wallet protection)
TRY_MAX_FIELD_BYTES=20000                              # per-field payload cap
# PORT intentionally unset: worker defaults to 8080, web/next to 3000. A shared PORT here
# would hijack `next dev` onto the worker port → self-proxy loop. Worker: `PORT=8080 npm start`.

# ── USDC EIP-712 domain — Arc USDC reports name()="USDC" (NOT "USD Coin"), version()="2".
# The wrong name causes "FiatTokenV2: invalid signature" at funding.
USDC_EIP712_NAME=USDC
USDC_EIP712_VERSION=2

# X1 — CCTP cross-chain funding (Base Sepolia -> Arc)
HOOK_ADDRESS=DEPLOY_AND_RECORD_ADDRESS_HERE
NEXT_PUBLIC_HOOK_ADDRESS=DEPLOY_AND_RECORD_ADDRESS_HERE
ARC_MESSAGE_TRANSMITTER=0xE737e5cEBEEBa77EFE34D4aa090756590b1CE275
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_TOKEN_MESSENGER=0x8FE6B999Dc680CcFDD5Bf7EB0974218be2542DAA
BASE_SEPOLIA_USDC=0x036CbD53842c5426634e7929541eC2318f3dCF7e
BASE_SEPOLIA_CCTP_DOMAIN=6
ARC_CCTP_DOMAIN=26
