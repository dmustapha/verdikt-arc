# Verdikt ACP Evaluator — credentials from app.virtuals.io/acp/agents/<your-agent>
# Placeholders only. The real values live in .env (gitignored). NEVER commit real keys.

# Agent's on-chain account (public) — the wallet shown on the agent page.
ACP_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
# Wallet ID from the agent page (public identifier, not a key).
ACP_WALLET_ID=<wallet-id>
# Signer private key: Signers tab -> + Add Signer -> Copy Key. PEM/base64 as given, verbatim.
# If multi-line PEM, keep it single-line with literal \n or wrap in quotes.
ACP_SIGNER_PRIVATE_KEY=<signer-private-key-SECRET>
# Optional: builderCode from the Settings tab (transaction attribution).
ACP_BUILDER_CODE=
# Verdikt worker whose verdict engine judges the deliverable (the same engine as everything else).
WORKER_URL=https://verdikt-worker.fly.dev
